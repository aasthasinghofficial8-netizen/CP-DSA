#include <bits/stdc++.h>
using namespace std;

int main() {
    int t,n,a;
    cin>>t;
    while(t--){
        cin>>n>>a;
        int p,q;
        vector<int> c;
        vector<int> d;
        for(int i=0; i<n;i++){
            cin>>p>>q;
            c.push_back(p);
            d.push_back(q);
        }
        int maxi=0;
        for(int i=0; i<n;i++){
            int sumc=0;
            int lo=d[i];
            int hi=d[i];
            for(int j=i;j<n;j++){
                sumc+=c[j];
                lo=std::min(lo, d[j]);
                hi=std::max(hi, d[j]);
                
                int gap=(hi-lo)*(hi-lo);
                int profit=(j-i+1)*a -sumc -gap;
                maxi=std::max(maxi, profit);
            }
        }
        cout<< maxi<<endl;
    }
}